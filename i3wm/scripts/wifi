#!/usr/bin/bash

blanco="#D3DAE3"
rojo="#B81D13"

wifi=$(nmcli connection show --active | awk '/wlo1/ {print $1}')
estado=$(nmcli networking connectivity)

if [[ "$estado" == "full" ]]; then
	echo "<span color='$blanco'>饇慐</span> <span color='$blanco'>$wifi</span>"
else
	echo "<span color='$rojo'>饇𢞁</span> <span color='$rojo'>down</span>"
fi
