#!/usr/bin/bash

menu=$(echo -e "display\npower\noutput" | dmenu -i -p "menu:")

if [[ "$menu" == "display" ]]; then
	display=$(echo -e "mirror\nexterno\nlaptop" | dmenu -i -p "menu:")
	case "$display" in
		mirror) bash ~/i3wm/scripts/mirror ;;
		externo) bash ~/i3wm/scripts/externo ;;
		laptop) bash ~/i3wm/scripts/laptop ;;
	esac
elif [[ "$menu" == "power" ]]; then
	power=$(echo -e "shutdown\nreboot\nsuspend" | dmenu -i -p "menu:")
	case "$power" in
		shutdown) systemctl poweroff ;;
		reboot) systemctl reboot ;;
		suspend) systemctl suspend ;;
	esac
elif [[ "$menu" == "output" ]]; then
	output=$(echo -e "headset\nlaptop" | dmenu -i -p "menu:")
	case "$output" in
		headset) pactl set-default-sink alsa_output.usb-Logitech_G733_Gaming_Headset-00.analog-stereo | pactl set-default-sink alsa_output.usb-Logitech_G733_Gaming_Headset-00.analog-stereo ;;
		laptop) pactl set-default-sink alsa_output.pci-0000_00_1f.3-platform-skl_hda_dsp_generic.HiFi__hw_sofhdadsp__sink | pactl set-default-source alsa_input.pci-0000_00_1f.3-platform-skl_hda_dsp_generic.HiFi__hw_sofhdadsp__source
	esac
fi
